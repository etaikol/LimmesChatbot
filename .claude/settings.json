{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m scripts.serve:*)",
      "Bash(python -m scripts.chat:*)",
      "Bash(python -m scripts.ingest:*)",
      "Bash(python -m scripts.scrape:*)",
      "Bash(pytest:*)",
      "Bash(pip install:*)",
      "Bash(pip show:*)",
      "Bash(pip list:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Read(**)",
      "Grep(**)",
      "Glob(**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(config/users.json)",
      "Read(**/wp-config.php)",
      "Read(**/.vscode/sftp.json)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  }
}
