# ═════════════════════════════════════════════════════════════════════
# Limmes Chatbot — environment variables
# Copy this file to `.env` and fill in the values you need.
# ═════════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Active client (matches config/clients/<id>.yaml) ────────────────
ACTIVE_CLIENT=limmes

# ── Runtime ─────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=pretty      # pretty | json
# LOG_FILE=logs/chatbot.log

# ── LLM ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai    # openai | anthropic
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
EMBEDDING_MODEL=text-embedding-3-small
# ANTHROPIC_API_KEY=

# ── RAG ─────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4
# VECTORSTORE_DIR=.vectorstore
# DATA_DIR=data

# ── Memory / sessions ───────────────────────────────────────────────
MEMORY_BACKEND=file    # memory | file | postgres
# SESSIONS_DIR=.sessions
MAX_HISTORY_TURNS=10

# ── Optional PostgreSQL backend ─────────────────────────────────────
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/chatbot

# ── HTTP API ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:8000
# Set to true in production — refuses to start if CORS is "*".
# Defaults to true so you MUST set your real domain(s) above.
API_STRICT_CORS=true

# ═════════════════════════════════════════════════════════════════════
# SECURITY & ANTI-ABUSE
# Tune these BEFORE going public. The defaults are sane for a
# small/medium business but you should harden them on a real deploy.
# ═════════════════════════════════════════════════════════════════════

# ── Input limits ────────────────────────────────────────────────────
# Hard cap on the request body in bytes (Content-Length). Anything
# larger is rejected with HTTP 413 *before* JSON parsing.
API_MAX_BODY_BYTES=65536
# Hard cap on a single user message in characters.
MAX_MESSAGE_CHARS=4000

# ── Transport hardening ─────────────────────────────────────────────
# Only enable HSTS once you serve over real HTTPS — never on http://
API_HSTS_ENABLED=false
API_HSTS_MAX_AGE=31536000

# ── Rate limiting (token bucket, per process) ───────────────────────
RATE_LIMIT_ENABLED=true
# Per source IP — protects from random bots / scanners.
RATE_LIMIT_IP_PER_MINUTE=30
RATE_LIMIT_IP_BURST=10
# Per session_id — protects from a single chat tab spamming.
RATE_LIMIT_SESSION_PER_MINUTE=12
RATE_LIMIT_SESSION_BURST=4

# ── Daily token / spend cap ─────────────────────────────────────────
# Once today's cap is reached every request returns HTTP 402 with a
# friendly "try again tomorrow" message until UTC midnight.
# Defaults are safe for a small business. Increase once you have real
# telemetry.  Resets at 00:00 UTC.
DAILY_TOKEN_CAP=500000
DAILY_USD_CAP=3
# BUDGET_STATE_FILE=.budget/state.json

# Override prices when your model is not in the built-in table or you
# negotiated a discount. Both are USD per 1,000 tokens.
PRICE_IN_USD_PER_1K=0
PRICE_OUT_USD_PER_1K=0

# ── Twilio (WhatsApp) ───────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Telegram ────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# Recommended: pass this same value to setWebhook?secret_token=...
# Telegram will then echo it in X-Telegram-Bot-Api-Secret-Token on
# every update; webhooks without it are rejected.
# TELEGRAM_WEBHOOK_SECRET=

# ── LINE Messaging ──────────────────────────────────────────────────
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=

# ═════════════════════════════════════════════════════════════════════
# WORDPRESS / PHP REST API INTEGRATION
# ─────────────────────────────────────────────────────────────────────
# The chatbot exposes a single REST endpoint:
#   POST https://<your-api-host>/chat
#   Headers: Content-Type: application/json
#             X-Api-Key: <CHATBOT_API_KEY>   ← only when key is set
#   Body:   {"message": "...", "session_id": "wp_<user_or_tab_id>",
#             "language": "he"}              ← language optional; auto-detected
#
# From PHP (WordPress):
#   $response = wp_remote_post( 'https://<api-host>/chat', [
#       'headers' => [
#           'Content-Type' => 'application/json',
#           'X-Api-Key'    => CHATBOT_API_KEY,   // defined in wp-config.php
#       ],
#       'body'    => json_encode([
#           'message'    => sanitize_text_field( $user_message ),
#           'session_id' => 'wp_' . get_current_user_id(),
#       ]),
#       'timeout' => 30,
#   ]);
#
# Production checklist:
#   1. Set CHATBOT_API_KEY to a long random string (e.g. openssl rand -hex 32)
#   2. Set API_CORS_ORIGINS to your WordPress domain (e.g. https://www.limmes.co.il)
#   3. Set API_STRICT_CORS=true so the app refuses to start if CORS is "*"
#   4. Put the same key in your WordPress wp-config.php or options table
# ═════════════════════════════════════════════════════════════════════

# Shared secret the WordPress site must send in X-Api-Key.
# Empty = disabled (open, rate-limiting still applies).
# CHATBOT_API_KEY=

# ── Prompt injection blocking ───────────────────────────────────────
# When true, messages matching injection heuristics are blocked (HTTP 400)
# rather than just logged. Default: true (safe).
BLOCK_PROMPT_INJECTION=true

# ── Backups ─────────────────────────────────────────────────────────
# The Docker backup sidecar keeps daily snapshots of vectorstore and
# sessions. Set how many days to keep before pruning old backups.
BACKUP_KEEP_DAYS=7
