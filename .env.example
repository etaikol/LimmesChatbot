# ═════════════════════════════════════════════════════════════════════
# Limmes Chatbot — environment variables
# Copy this file to `.env` and fill in the values you need.
# ═════════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Active client (matches config/clients/<id>.yaml) ────────────────
ACTIVE_CLIENT=limmes

# ── Runtime ─────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=pretty      # pretty | json
# LOG_FILE=logs/chatbot.log

# ── LLM ─────────────────────────────────────────────────────────────
LLM_PROVIDER=openai    # openai | anthropic
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
EMBEDDING_MODEL=text-embedding-3-small
# ANTHROPIC_API_KEY=

# ── RAG ─────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4
# VECTORSTORE_DIR=.vectorstore
# DATA_DIR=data

# ── Memory / sessions ───────────────────────────────────────────────
MEMORY_BACKEND=file    # memory | file | postgres
# SESSIONS_DIR=.sessions
MAX_HISTORY_TURNS=10

# ── Optional PostgreSQL backend ─────────────────────────────────────
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/chatbot

# ── HTTP API ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

# ── Twilio (WhatsApp) ───────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Telegram ────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── LINE Messaging ──────────────────────────────────────────────────
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
