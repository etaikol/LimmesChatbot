# ── Required ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Client branding ───────────────────────────────────────────
CLIENT_NAME=Mario's Pizza
SYSTEM_PROMPT=You are a helpful assistant for Mario's Pizza. Help customers with menu questions, opening hours, reservations, and directions. Never discuss competitors. Be friendly and concise.

# ── Integration Tokens ────────────────────────────────────────
# Telegram: Get token from @BotFather
TELEGRAM_TOKEN=

# WhatsApp via Twilio: Get auth token from Twilio console (RECOMMENDED for production)
# This enables signature validation for secure webhook communication
TWILIO_AUTH_TOKEN=

# ── Model settings (optional overrides) ──────────────────────
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
MODEL_TEMPERATURE=0.7
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=4

# ── Paths ─────────────────────────────────────────────────────
PDF_DIRECTORY=pdfs
VECTORSTORE_DIR=.chroma
